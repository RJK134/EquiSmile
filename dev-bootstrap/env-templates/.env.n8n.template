# =============================================================================
# dev-bootstrap n8n env
# Copy to ../.env.n8n (the bootstrap script does this for you).
# DO NOT COMMIT THIS FILE WITH REAL SECRETS.
# =============================================================================

# --- Timezone ---------------------------------------------------------------
TZ=Europe/Zurich
GENERIC_TIMEZONE=Europe/Zurich

# --- n8n encryption ---------------------------------------------------------
# REQUIRED. Generate with: openssl rand -hex 32
# If you ever lose this key, every stored credential becomes unreadable.
N8N_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# --- n8n basic auth (UI login) ---------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-me

# --- n8n host / webhook URL ------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/

# --- n8n's dedicated Postgres (internal-only, not exposed on host) ---------
N8N_DB_USER=n8n
N8N_DB_PASSWORD=n8npass
N8N_DB_NAME=n8n
