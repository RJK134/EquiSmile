# =============================================================================
# dev-bootstrap app env
# Copy to ../.env (the bootstrap script does this for you).
# DO NOT COMMIT THIS FILE WITH REAL SECRETS.
# =============================================================================

# --- Timezone ---------------------------------------------------------------
TZ=Europe/Zurich

# --- Database (app dev DB, exposed on host port) ----------------------------
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpass
POSTGRES_DB=devdb
POSTGRES_PORT=5432
DATABASE_URL=postgresql://devuser:devpass@localhost:5432/devdb?schema=public

# --- Redis ------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Auth (JWT) -------------------------------------------------------------
# Generate with: openssl rand -hex 48
JWT_SECRET=replace-me-with-long-random-string
JWT_EXPIRES_IN=7d

# --- SMTP (captured locally by Mailpit) -------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Dev <no-reply@dev.local>"
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# --- pgAdmin ---------------------------------------------------------------
PGADMIN_EMAIL=admin@dev.local
PGADMIN_PASSWORD=devpass
PGADMIN_PORT=5050

# --- Azure (optional) -------------------------------------------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=

# --- Moodle (optional) ------------------------------------------------------
MOODLE_BASE_URL=
MOODLE_TOKEN=

# --- n8n webhook (called from the app) --------------------------------------
N8N_WEBHOOK_URL=http://localhost:5678/webhook/
N8N_WEBHOOK_SECRET=
