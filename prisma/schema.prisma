generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Channel {
  WHATSAPP
  EMAIL
}

enum PreferredChannel {
  WHATSAPP
  EMAIL
  PHONE
}

enum TriageStatus {
  NEW
  PARSED
  NEEDS_INFO
  TRIAGED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum RequestType {
  ROUTINE_DENTAL
  FOLLOW_UP
  URGENT_ISSUE
  FIRST_VISIT
  ADMIN
}

enum UrgencyLevel {
  URGENT
  SOON
  ROUTINE
}

enum PreferredTimeBand {
  AM
  PM
  ANY
}

enum PlanningStatus {
  UNTRIAGED
  READY_FOR_REVIEW
  PLANNING_POOL
  CLUSTERED
  PROPOSED
  BOOKED
  COMPLETED
  CANCELLED
}

enum TriageTaskType {
  URGENT_REVIEW
  ASK_FOR_POSTCODE
  ASK_HORSE_COUNT
  CLARIFY_SYMPTOMS
  MANUAL_CLASSIFICATION
}

enum TriageTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum RouteRunStatus {
  DRAFT
  PROPOSED
  APPROVED
  BOOKED
  COMPLETED
}

enum StopStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  SKIPPED
}

enum AppointmentStatus {
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ConfirmationChannel {
  WHATSAPP
  EMAIL
  PHONE
}

enum InvoiceStatus {
  NOT_NEEDED
  PENDING
  SENT
  PAID
}

enum StaffRole {
  VET
  ADMIN
  NURSE
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Customer {
  id                String           @id @default(uuid())
  fullName          String
  mobilePhone       String?          @unique
  email             String?          @unique
  preferredChannel  PreferredChannel @default(WHATSAPP)
  preferredLanguage String           @default("en")
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  yards         Yard[]
  horses        Horse[]
  enquiries     Enquiry[]
  visitRequests VisitRequest[]

  @@index([fullName])
}

model Yard {
  id            String   @id @default(uuid())
  customerId    String
  yardName      String
  addressLine1  String
  addressLine2  String?
  town          String
  county        String?
  postcode      String
  latitude       Float?
  longitude      Float?
  geocodeFailed  Boolean  @default(false)
  geocodedAt     DateTime?
  accessNotes    String?
  areaLabel      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer      Customer       @relation(fields: [customerId], references: [id])
  horses        Horse[]
  enquiries     Enquiry[]
  visitRequests VisitRequest[]
  routeRunStops RouteRunStop[]

  @@index([customerId])
  @@index([postcode])
  @@index([areaLabel])
}

model Horse {
  id            String    @id @default(uuid())
  customerId    String
  primaryYardId String?
  horseName     String
  age           Int?
  notes         String?
  dentalDueDate DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id])
  primaryYard Yard?    @relation(fields: [primaryYardId], references: [id])

  @@index([customerId])
  @@index([primaryYardId])
}

model Enquiry {
  id                 String       @id @default(uuid())
  channel            Channel
  externalMessageId  String?      @unique
  customerId         String?
  yardId             String?
  sourceFrom         String
  subject            String?
  rawText            String
  receivedAt         DateTime
  threadKey          String?
  triageStatus       TriageStatus @default(NEW)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  yard     Yard?     @relation(fields: [yardId], references: [id])

  messages      EnquiryMessage[]
  visitRequests VisitRequest[]

  @@index([customerId])
  @@index([triageStatus])
  @@index([receivedAt])
}

model EnquiryMessage {
  id                 String           @id @default(uuid())
  enquiryId          String
  direction          MessageDirection
  channel            Channel
  messageText        String
  sentOrReceivedAt   DateTime
  externalMessageId  String?

  enquiry Enquiry @relation(fields: [enquiryId], references: [id])

  @@index([enquiryId])
}

model VisitRequest {
  id                       String           @id @default(uuid())
  enquiryId                String?
  customerId               String
  yardId                   String?
  requestType              RequestType
  urgencyLevel             UrgencyLevel     @default(ROUTINE)
  clinicalFlags            String[]
  horseCount               Int?
  specificHorses           String[]
  preferredDays            String[]
  preferredTimeBand        PreferredTimeBand @default(ANY)
  earliestBookDate         DateTime?
  latestBookDate           DateTime?
  needsMoreInfo            Boolean          @default(false)
  planningStatus           PlanningStatus   @default(UNTRIAGED)
  estimatedDurationMinutes Int?
  revenueEstimate          Float?
  followUpAttempts         Int              @default(0)
  lastFollowUpAt           DateTime?
  autoTriageConfidence     Float?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  enquiry      Enquiry?      @relation(fields: [enquiryId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  yard         Yard?         @relation(fields: [yardId], references: [id])

  triageTasks    TriageTask[]
  auditLogs      TriageAuditLog[]
  routeRunStops  RouteRunStop[]
  appointments   Appointment[]

  @@index([customerId])
  @@index([planningStatus])
  @@index([urgencyLevel])
}

model TriageTask {
  id             String           @id @default(uuid())
  visitRequestId String
  taskType       TriageTaskType
  assignedTo     String?
  dueAt          DateTime?
  status         TriageTaskStatus @default(OPEN)
  notes          String?
  escalatedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  visitRequest VisitRequest @relation(fields: [visitRequestId], references: [id])

  @@index([visitRequestId])
  @@index([status])
}

model TriageAuditLog {
  id             String   @id @default(uuid())
  visitRequestId String
  action         String
  field          String
  previousValue  String?
  newValue       String
  reason         String
  performedBy    String   @default("admin")
  createdAt      DateTime @default(now())

  visitRequest VisitRequest @relation(fields: [visitRequestId], references: [id])

  @@index([visitRequestId])
  @@index([createdAt])
}

model RouteRun {
  id                  String         @id @default(uuid())
  runDate             DateTime
  homeBaseAddress     String
  startTime           DateTime?
  endTime             DateTime?
  status              RouteRunStatus @default(DRAFT)
  totalDistanceMeters Int?
  totalTravelMinutes  Int?
  totalVisitMinutes   Int?
  totalJobs           Int?
  totalHorses         Int?
  optimizationScore   Float?
  notes               String?
  leadStaffId         String?
  createdAt           DateTime       @default(now())

  stops        RouteRunStop[]
  appointments Appointment[]
  leadStaff    Staff?              @relation("RouteRunLead", fields: [leadStaffId], references: [id], onDelete: SetNull)
  assistants   RouteRunAssistant[]

  @@index([runDate])
  @@index([status])
  @@index([leadStaffId])
}

model RouteRunStop {
  id                      String     @id @default(uuid())
  routeRunId              String
  sequenceNo              Int
  visitRequestId          String?
  yardId                  String
  plannedArrival          DateTime?
  plannedDeparture        DateTime?
  serviceMinutes          Int?
  travelFromPrevMinutes   Int?
  travelFromPrevMeters    Int?
  stopStatus              StopStatus @default(PLANNED)
  optimizationScore       Float?

  routeRun     RouteRun      @relation(fields: [routeRunId], references: [id])
  visitRequest VisitRequest? @relation(fields: [visitRequestId], references: [id])
  yard         Yard          @relation(fields: [yardId], references: [id])

  @@index([routeRunId])
}

model Appointment {
  id                  String              @id @default(uuid())
  visitRequestId      String
  routeRunId          String?
  appointmentStart    DateTime
  appointmentEnd      DateTime
  status              AppointmentStatus   @default(PROPOSED)
  confirmationChannel ConfirmationChannel?
  confirmationSentAt  DateTime?
  reminderSentAt24h   DateTime?
  reminderSentAt2h    DateTime?
  cancellationReason  String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  visitRequest VisitRequest  @relation(fields: [visitRequestId], references: [id])
  routeRun     RouteRun?     @relation(fields: [routeRunId], references: [id])
  visitOutcome VisitOutcome?
  assignments  AppointmentAssignment[]

  @@index([visitRequestId])
  @@index([status])
  @@index([appointmentStart])
}

model VisitOutcome {
  id                String        @id @default(uuid())
  appointmentId     String        @unique
  completedAt       DateTime
  notes             String?
  followUpRequired  Boolean       @default(false)
  followUpDueDate   DateTime?
  nextDentalDueDate DateTime?
  invoiceStatus     InvoiceStatus @default(NOT_NEEDED)

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

// ---------------------------------------------------------------------------
// Staff — operators (vets, nurses, admin). Separate from the Auth.js User
// model so domain assignments stay decoupled from authentication plumbing.
// A Staff row MAY link to an Auth User via userId (optional 1:1) so that
// signing-in auto-attributes domain actions when desired.
// ---------------------------------------------------------------------------

model Staff {
  id        String    @id @default(uuid())
  name      String
  email     String?   @unique
  phone     String?
  role      StaffRole @default(VET)
  colour    String?   // hex, used for calendar pills (e.g. "#9b214d")
  active    Boolean   @default(true)
  notes     String?
  userId    String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user                  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointmentAssignments AppointmentAssignment[]
  routeRunsLed          RouteRun[]             @relation("RouteRunLead")
  routeRunAssistance    RouteRunAssistant[]

  @@index([role])
  @@index([active])
}

// Assignment of a Staff member to an Appointment. `primary` flag marks the
// lead vet for the visit. Multiple rows support joint rounds (e.g. lead +
// assistant, or two vets sharing the visit).
model AppointmentAssignment {
  id            String   @id @default(uuid())
  appointmentId String
  staffId       String
  primary       Boolean  @default(false)
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  staff       Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, staffId])
  @@index([staffId])
  @@index([appointmentId])
}

// Join for joint route runs — lead is stored on RouteRun.leadStaffId; this
// table records additional vets/nurses coming along for part or all of the
// run.
model RouteRunAssistant {
  id         String   @id @default(uuid())
  routeRunId String
  staffId    String
  createdAt  DateTime @default(now())

  routeRun RouteRun @relation(fields: [routeRunId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([routeRunId, staffId])
  @@index([staffId])
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) models — internal operator sign-in via GitHub OAuth.
// These are separate from the domain models above and drive app access only.
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  githubLogin   String?   @unique
  role          String    @default("vet")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  staff    Staff?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
