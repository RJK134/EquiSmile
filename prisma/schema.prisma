generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Channel {
  WHATSAPP
  EMAIL
}

enum PreferredChannel {
  WHATSAPP
  EMAIL
  PHONE
}

enum TriageStatus {
  NEW
  PARSED
  NEEDS_INFO
  TRIAGED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum RequestType {
  ROUTINE_DENTAL
  FOLLOW_UP
  URGENT_ISSUE
  FIRST_VISIT
  ADMIN
}

enum UrgencyLevel {
  URGENT
  SOON
  ROUTINE
}

enum PreferredTimeBand {
  AM
  PM
  ANY
}

enum PlanningStatus {
  UNTRIAGED
  READY_FOR_REVIEW
  PLANNING_POOL
  CLUSTERED
  PROPOSED
  BOOKED
  COMPLETED
  CANCELLED
}

enum TriageTaskType {
  URGENT_REVIEW
  ASK_FOR_POSTCODE
  ASK_HORSE_COUNT
  CLARIFY_SYMPTOMS
  MANUAL_CLASSIFICATION
}

enum TriageTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum RouteRunStatus {
  DRAFT
  PROPOSED
  APPROVED
  BOOKED
  COMPLETED
}

enum StopStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  SKIPPED
}

enum AppointmentStatus {
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ConfirmationChannel {
  WHATSAPP
  EMAIL
  PHONE
}

enum InvoiceStatus {
  NOT_NEEDED
  PENDING
  SENT
  PAID
}

enum StaffRole {
  VET
  ADMIN
  NURSE
}

enum AttachmentKind {
  DENTAL_CHART_PDF
  DENTAL_IMAGE
  XRAY_IMAGE
  OTHER_IMAGE
  OTHER
}

enum FindingCategory {
  HOOK
  WAVE
  RAMP
  DIASTEMA
  EOTRH
  FRACTURE
  CARIES
  WEAR
  MISSING
  OTHER
}

enum FindingSeverity {
  MILD
  MODERATE
  SEVERE
}

enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Customer {
  id                String           @id @default(uuid())
  fullName          String
  mobilePhone       String?          @unique
  email             String?          @unique
  preferredChannel  PreferredChannel @default(WHATSAPP)
  preferredLanguage String           @default("en")
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  yards         Yard[]
  horses        Horse[]
  enquiries     Enquiry[]
  visitRequests VisitRequest[]

  @@index([fullName])
}

model Yard {
  id            String   @id @default(uuid())
  customerId    String
  yardName      String
  addressLine1  String
  addressLine2  String?
  town          String
  county        String?
  postcode      String
  latitude       Float?
  longitude      Float?
  geocodeFailed  Boolean  @default(false)
  geocodedAt     DateTime?
  // AMBER-06 remediation — record provenance / quality of the geocode result.
  geocodeSource    String?
  geocodePrecision String?  // ROOFTOP / RANGE_INTERPOLATED / GEOMETRIC_CENTER / APPROXIMATE
  formattedAddress String?
  accessNotes    String?
  areaLabel      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer      Customer       @relation(fields: [customerId], references: [id])
  horses        Horse[]
  enquiries     Enquiry[]
  visitRequests VisitRequest[]
  routeRunStops RouteRunStop[]

  @@index([customerId])
  @@index([postcode])
  @@index([areaLabel])
}

model Horse {
  id            String    @id @default(uuid())
  customerId    String
  primaryYardId String?
  horseName     String
  age           Int?
  notes         String?
  dentalDueDate DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer    Customer @relation(fields: [customerId], references: [id])
  primaryYard Yard?    @relation(fields: [primaryYardId], references: [id])

  attachments    HorseAttachment[]
  dentalCharts   DentalChart[]
  findings       ClinicalFinding[]
  prescriptions  Prescription[]

  @@index([customerId])
  @@index([primaryYardId])
}

model Enquiry {
  id                 String       @id @default(uuid())
  channel            Channel
  externalMessageId  String?      @unique
  customerId         String?
  yardId             String?
  sourceFrom         String
  subject            String?
  rawText            String
  receivedAt         DateTime
  threadKey          String?
  triageStatus       TriageStatus @default(NEW)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  yard     Yard?     @relation(fields: [yardId], references: [id])

  messages      EnquiryMessage[]
  visitRequests VisitRequest[]

  @@index([customerId])
  @@index([triageStatus])
  @@index([receivedAt])
}

model EnquiryMessage {
  id                 String           @id @default(uuid())
  enquiryId          String
  direction          MessageDirection
  channel            Channel
  messageText        String
  sentOrReceivedAt   DateTime
  externalMessageId  String?

  enquiry Enquiry @relation(fields: [enquiryId], references: [id])

  @@index([enquiryId])
}

model VisitRequest {
  id                       String           @id @default(uuid())
  enquiryId                String?
  customerId               String
  yardId                   String?
  requestType              RequestType
  urgencyLevel             UrgencyLevel     @default(ROUTINE)
  clinicalFlags            String[]
  horseCount               Int?
  specificHorses           String[]
  preferredDays            String[]
  preferredTimeBand        PreferredTimeBand @default(ANY)
  earliestBookDate         DateTime?
  latestBookDate           DateTime?
  needsMoreInfo            Boolean          @default(false)
  planningStatus           PlanningStatus   @default(UNTRIAGED)
  estimatedDurationMinutes Int?
  revenueEstimate          Float?
  followUpAttempts         Int              @default(0)
  lastFollowUpAt           DateTime?
  autoTriageConfidence     Float?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  enquiry      Enquiry?      @relation(fields: [enquiryId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  yard         Yard?         @relation(fields: [yardId], references: [id])

  triageTasks    TriageTask[]
  auditLogs      TriageAuditLog[]
  routeRunStops  RouteRunStop[]
  appointments   Appointment[]
  prescriptions  Prescription[]

  @@index([customerId])
  @@index([planningStatus])
  @@index([urgencyLevel])
}

model TriageTask {
  id             String           @id @default(uuid())
  visitRequestId String
  taskType       TriageTaskType
  assignedTo     String?
  dueAt          DateTime?
  status         TriageTaskStatus @default(OPEN)
  notes          String?
  escalatedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  visitRequest VisitRequest @relation(fields: [visitRequestId], references: [id])

  @@index([visitRequestId])
  @@index([status])
}

model TriageAuditLog {
  id             String   @id @default(uuid())
  visitRequestId String
  action         String
  field          String
  previousValue  String?
  newValue       String
  reason         String
  performedBy    String   @default("admin")
  createdAt      DateTime @default(now())

  visitRequest VisitRequest @relation(fields: [visitRequestId], references: [id])

  @@index([visitRequestId])
  @@index([createdAt])
}

model RouteRun {
  id                  String         @id @default(uuid())
  runDate             DateTime
  homeBaseAddress     String
  startTime           DateTime?
  endTime             DateTime?
  status              RouteRunStatus @default(DRAFT)
  totalDistanceMeters Int?
  totalTravelMinutes  Int?
  totalVisitMinutes   Int?
  totalJobs           Int?
  totalHorses         Int?
  optimizationScore   Float?
  notes               String?
  leadStaffId         String?
  createdAt           DateTime       @default(now())

  stops        RouteRunStop[]
  appointments Appointment[]
  leadStaff    Staff?              @relation("RouteRunLead", fields: [leadStaffId], references: [id], onDelete: SetNull)
  assistants   RouteRunAssistant[]

  @@index([runDate])
  @@index([status])
  @@index([leadStaffId])
}

model RouteRunStop {
  id                      String     @id @default(uuid())
  routeRunId              String
  sequenceNo              Int
  visitRequestId          String?
  yardId                  String
  plannedArrival          DateTime?
  plannedDeparture        DateTime?
  serviceMinutes          Int?
  travelFromPrevMinutes   Int?
  travelFromPrevMeters    Int?
  stopStatus              StopStatus @default(PLANNED)
  optimizationScore       Float?

  routeRun     RouteRun      @relation(fields: [routeRunId], references: [id])
  visitRequest VisitRequest? @relation(fields: [visitRequestId], references: [id])
  yard         Yard          @relation(fields: [yardId], references: [id])

  @@index([routeRunId])
}

model Appointment {
  id                  String              @id @default(uuid())
  visitRequestId      String
  routeRunId          String?
  appointmentStart    DateTime
  appointmentEnd      DateTime
  status              AppointmentStatus   @default(PROPOSED)
  confirmationChannel ConfirmationChannel?
  confirmationSentAt  DateTime?
  reminderSentAt24h   DateTime?
  reminderSentAt2h    DateTime?
  cancellationReason  String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  visitRequest VisitRequest  @relation(fields: [visitRequestId], references: [id])
  routeRun     RouteRun?     @relation(fields: [routeRunId], references: [id])
  visitOutcome VisitOutcome?
  assignments  AppointmentAssignment[]
  prescriptions Prescription[]
  confirmationDispatches ConfirmationDispatch[]
  responses              AppointmentResponse[]
  statusHistory          AppointmentStatusHistory[]

  @@index([visitRequestId])
  @@index([status])
  @@index([appointmentStart])
}

model VisitOutcome {
  id                String        @id @default(uuid())
  appointmentId     String        @unique
  completedAt       DateTime
  notes             String?
  followUpRequired  Boolean       @default(false)
  followUpDueDate   DateTime?
  nextDentalDueDate DateTime?
  invoiceStatus     InvoiceStatus @default(NOT_NEEDED)

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

// ---------------------------------------------------------------------------
// Staff — operators (vets, nurses, admin). Separate from the Auth.js User
// model so domain assignments stay decoupled from authentication plumbing.
// A Staff row MAY link to an Auth User via userId (optional 1:1) so that
// signing-in auto-attributes domain actions when desired.
// ---------------------------------------------------------------------------

model Staff {
  id        String    @id @default(uuid())
  name      String
  email     String?   @unique
  phone     String?
  role      StaffRole @default(VET)
  colour    String?   // hex, used for calendar pills (e.g. "#9b214d")
  active    Boolean   @default(true)
  notes     String?
  userId    String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user                  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointmentAssignments AppointmentAssignment[]
  routeRunsLed          RouteRun[]             @relation("RouteRunLead")
  routeRunAssistance    RouteRunAssistant[]
  attachmentsUploaded   HorseAttachment[]
  dentalChartsRecorded  DentalChart[]
  findingsCreated       ClinicalFinding[]
  prescriptionsWritten  Prescription[]

  @@index([role])
  @@index([active])
}

// Assignment of a Staff member to an Appointment. `primary` flag marks the
// lead vet for the visit. Multiple rows support joint rounds (e.g. lead +
// assistant, or two vets sharing the visit).
model AppointmentAssignment {
  id            String   @id @default(uuid())
  appointmentId String
  staffId       String
  primary       Boolean  @default(false)
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  staff       Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, staffId])
  @@index([staffId])
  @@index([appointmentId])
}

// Join for joint route runs — lead is stored on RouteRun.leadStaffId; this
// table records additional vets/nurses coming along for part or all of the
// run.
model RouteRunAssistant {
  id         String   @id @default(uuid())
  routeRunId String
  staffId    String
  createdAt  DateTime @default(now())

  routeRun RouteRun @relation(fields: [routeRunId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([routeRunId, staffId])
  @@index([staffId])
}

// ---------------------------------------------------------------------------
// Idempotency keys — phase 13 (AMBER-14 remediation).
// Persists "I've already processed this key" markers across restarts and
// multiple app instances. Replaces the in-memory Set previously held in
// lib/utils/retry.ts. Rows older than `expiresAt` are safe to prune.
// ---------------------------------------------------------------------------

model IdempotencyKey {
  key         String   @id
  scope       String
  createdAt   DateTime @default(now())
  expiresAt   DateTime?

  @@index([scope])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Security audit log — Phase 14 PR B.
//
// Append-only record of security-relevant events: sign-in denials, exports
// of customer data, attachment deletion, clinical record mutations, role
// changes, and any other sensitive action that would matter during an
// incident response or a regulator audit.
//
// The `actor` column stores the best-available identifier (githubLogin,
// email, or user id); if the event happened without a session (e.g. a
// background job) it records `system`. We deliberately do NOT store
// session tokens, IP addresses, or request bodies — just who did what,
// when, and against which target.
// ---------------------------------------------------------------------------

enum SecurityAuditEvent {
  SIGN_IN_DENIED
  ROLE_CHANGED
  EXPORT_DATASET
  ATTACHMENT_DELETED
  ATTACHMENT_DOWNLOADED
  CLINICAL_RECORD_CREATED
  CLINICAL_RECORD_UPDATED
  CLINICAL_RECORD_DELETED
  PRESCRIPTION_STATUS_CHANGED
  VISION_ANALYSIS_INVOKED
  STAFF_CREATED
  STAFF_UPDATED
  STAFF_DEACTIVATED
  CUSTOMER_DELETED
  YARD_DELETED
  HORSE_DELETED
  OTHER
}

model SecurityAuditLog {
  id         String             @id @default(uuid())
  event      SecurityAuditEvent
  actor      String
  actorRole  String?
  targetType String?  // e.g. "Attachment", "Customer", "Staff"
  targetId   String?
  detail     String?  // short free-text summary; MUST NOT contain secrets
  createdAt  DateTime           @default(now())

  @@index([event])
  @@index([actor])
  @@index([createdAt])
  @@index([targetType, targetId])
}

// ---------------------------------------------------------------------------
// Clinical records — phase 12.
//
// A Horse is a patient. Clinical records accumulate over a horse's life:
//   - HorseAttachment: uploaded files (PDF dental charts, clinical photos,
//     X-rays). Storage path is kept relative so backends (local FS/S3) are
//     swappable.
//   - DentalChart: a snapshot at a moment in time, usually linked to an
//     Appointment. Holds the general notes; individual tooth-level entries
//     live on ClinicalFinding.
//   - ClinicalFinding: one row per issue on one tooth (or region). Tooth
//     IDs use the Triadan system as free text (e.g. "106" for upper-left
//     first molar) so it stays flexible.
//   - Prescription: medications/treatments with dosage, duration, and
//     withdrawal period.
// ---------------------------------------------------------------------------

model HorseAttachment {
  id           String          @id @default(uuid())
  horseId      String
  kind         AttachmentKind  @default(OTHER)
  filename     String
  mimeType     String
  sizeBytes    Int
  storagePath  String          // relative path inside ATTACHMENT_STORAGE_DIR
  description  String?
  uploadedById String?
  uploadedAt   DateTime        @default(now())

  horse        Horse               @relation(fields: [horseId], references: [id], onDelete: Cascade)
  uploadedBy   Staff?              @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  dentalChart  DentalChart?        @relation("DentalChartAttachment")
  findings     ClinicalFinding[]

  @@index([horseId])
  @@index([kind])
  @@index([uploadedAt])
}

model DentalChart {
  id            String   @id @default(uuid())
  horseId       String
  appointmentId String?
  recordedById  String?
  recordedAt    DateTime @default(now())
  generalNotes  String?
  attachmentId  String?  @unique

  horse       Horse             @relation(fields: [horseId], references: [id], onDelete: Cascade)
  recordedBy  Staff?            @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  attachment  HorseAttachment?  @relation("DentalChartAttachment", fields: [attachmentId], references: [id], onDelete: SetNull)
  findings    ClinicalFinding[]

  @@index([horseId])
  @@index([recordedAt])
}

model ClinicalFinding {
  id            String          @id @default(uuid())
  horseId       String
  dentalChartId String?
  findingDate   DateTime        @default(now())
  toothId       String?         // Triadan code, free text
  category      FindingCategory @default(OTHER)
  severity      FindingSeverity @default(MILD)
  description   String
  attachmentId  String?
  createdById   String?
  createdAt     DateTime        @default(now())

  horse       Horse            @relation(fields: [horseId], references: [id], onDelete: Cascade)
  dentalChart DentalChart?     @relation(fields: [dentalChartId], references: [id], onDelete: SetNull)
  attachment  HorseAttachment? @relation(fields: [attachmentId], references: [id], onDelete: SetNull)
  createdBy   Staff?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([horseId])
  @@index([dentalChartId])
  @@index([category])
  @@index([findingDate])
}

model Prescription {
  id                    String             @id @default(uuid())
  horseId               String
  visitRequestId        String?
  appointmentId         String?
  prescribedAt          DateTime           @default(now())
  prescribedById        String?
  medicineName          String
  dosage                String             // free text, e.g. "10 mg/kg PO BID"
  durationDays          Int?
  withdrawalPeriodDays  Int?
  instructions          String?
  status                PrescriptionStatus @default(ACTIVE)
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancelledReason       String?

  horse        Horse         @relation(fields: [horseId], references: [id], onDelete: Cascade)
  prescribedBy Staff?        @relation(fields: [prescribedById], references: [id], onDelete: SetNull)
  visitRequest VisitRequest? @relation(fields: [visitRequestId], references: [id], onDelete: SetNull)
  appointment  Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([horseId])
  @@index([status])
  @@index([prescribedAt])
}

// ---------------------------------------------------------------------------
// Appointment auditability — Phase 14 PR D (AMBER-10, AMBER-11, AMBER-13).
// ---------------------------------------------------------------------------

// AMBER-10: every outbound confirmation send produces one row.
model ConfirmationDispatch {
  id            String              @id @default(uuid())
  appointmentId String
  channel       ConfirmationChannel
  sentAt        DateTime            @default(now())
  success       Boolean             @default(true)
  externalMessageId String?
  errorMessage  String?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([sentAt])
}

// AMBER-11: inbound customer replies to confirmations (confirmed / cancelled /
// reschedule) linked directly to the appointment.
enum AppointmentResponseKind {
  CONFIRMED
  CANCELLED
  RESCHEDULE_REQUESTED
  OTHER
}

model AppointmentResponse {
  id            String                  @id @default(uuid())
  appointmentId String
  kind          AppointmentResponseKind @default(OTHER)
  channel       ConfirmationChannel
  receivedAt    DateTime                @default(now())
  rawText       String?
  // Optional link back to the EnquiryMessage we parsed this reply out of.
  enquiryMessageId String?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([kind])
  @@index([receivedAt])
}

// AMBER-13: tamper-evident status history. Each `Appointment.status` change
// emits one row. The domain service writes these alongside status mutations.
model AppointmentStatusHistory {
  id            String            @id @default(uuid())
  appointmentId String
  fromStatus    AppointmentStatus?
  toStatus      AppointmentStatus
  changedBy     String
  reason        String?
  changedAt     DateTime          @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([changedAt])
}

// AMBER-15: dead-letter queue for permanent failures after the retry loop
// exhausts. Callers enqueue here when `withRetry` throws a RetryError; an
// operator can inspect and replay later.
enum FailedOperationStatus {
  PENDING
  REPLAYED
  ABANDONED
}

model FailedOperation {
  id          String                @id @default(uuid())
  scope       String                // e.g. "whatsapp-send-text"
  operationKey String?              // idempotency key if one existed
  payload     String                // JSON string, redacted
  lastError   String
  attempts    Int                   @default(0)
  status      FailedOperationStatus @default(PENDING)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([scope])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Auth.js (NextAuth v5) models — internal operator sign-in via GitHub OAuth.
// These are separate from the domain models above and drive app access only.
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  githubLogin   String?   @unique
  role          String    @default("vet")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  staff    Staff?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
