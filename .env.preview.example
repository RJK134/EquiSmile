# Vercel Preview environment template.
#
# Set every var below in: Vercel Dashboard → Project → Settings →
# Environment Variables, with the "Preview" environment ticked.
# (Copy this file; do NOT commit a real .env.preview to git.)
#
# A preview deployment populated with these values lets a reviewer
# click the PR's Vercel comment link and immediately interact with
# seeded demo data — no GitHub-OAuth flow, no production banking
# creds.
#
# For the full env-var matrix (production / integration creds /
# finance config) see docs/VERCEL.md §2.

# ─── Required ───────────────────────────────────────────────────────

# Postgres connection. RECOMMENDED: install the Neon Vercel
# integration (Vercel Marketplace → Neon) — it auto-creates a
# branch DB per preview, isolated from production, with this var
# auto-populated. Manual fallback: any managed Postgres with
# sslmode=require and a few spare connections.
DATABASE_URL=postgresql://USER:PASS@HOST.neon.tech/equismile?sslmode=require&pool_timeout=20&connection_limit=10

# Auth.js JWT/session secret — DIFFERENT value to production.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Optional callback override. Leave UNSET on Preview — Vercel
# populates VERCEL_URL on each deploy and Auth.js's trustHost
# uses it. Only set this if you've added a stable preview alias.
# AUTH_URL=

# Same advice — leave unset; CORS allow-list will derive from the
# preview URL via VERCEL_URL.
# NEXT_PUBLIC_APP_URL=

# Required even on preview. Webhook handlers fail-closed when
# unset (see KNOWN_ISSUES.md KI-006). Use a different value to
# production so a leaked preview key can't authenticate against
# the live n8n.
N8N_API_KEY=preview-only-pseudo-random-string

# ─── Demo / preview behaviour ───────────────────────────────────────

# Enables the persona picker (one-tap sign-in as Kathelijne /
# Alex / Sophie / Léa / Marc), the WhatsApp + email simulators,
# and the placeholder Swiss QR-IBAN. The build script runs
# `npx prisma db seed` only when DEMO_MODE=true.
DEMO_MODE=true

# Optional. Forces real Google Maps calls (Geocoding +
# Route Optimization) even with DEMO_MODE=true. Costs real GCP
# billing per request — leave unset unless the reviewer needs to
# see live routing.
# EQUISMILE_LIVE_MAPS=true
# GOOGLE_MAPS_API_KEY=
# GCP_PROJECT_ID=
# NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# ─── Auto-supplied by Vercel (do not set manually) ──────────────────
# VERCEL=1
# VERCEL_ENV=preview
# VERCEL_URL=equismile-git-<branch>-<team>.vercel.app
# VERCEL_GIT_COMMIT_SHA=<sha>            # surfaces in the login footer
